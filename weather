import tkinter as tk
from tkinter import ttk, messagebox
import json
import os
from datetime import datetime

DATA_FILE = 'weather_data.json'

def is_valid_date(date_text):
    try:
        datetime.strptime(date_text, '%Y-%m-%d')
        return True
    except ValueError:
        return False

class WeatherDiary:
    def __init__(self, root):
        self.root = root
        self.root.title("Weather Diary")
        self.records = []

        # Ввод данных
        tk.Label(root, text="Дата (ГГГГ-ММ-ДД):").grid(row=0, column=0)
        self.date_var = tk.StringVar()
        tk.Entry(root, textvariable=self.date_var).grid(row=0, column=1)

        tk.Label(root, text="Температура:").grid(row=1, column=0)
        self.temp_var = tk.StringVar()
        tk.Entry(root, textvariable=self.temp_var).grid(row=1, column=1)

        tk.Label(root, text="Описание погоды:").grid(row=2, column=0)
        self.desc_var = tk.StringVar()
        tk.Entry(root, textvariable=self.desc_var).grid(row=2, column=1)

        self.rain_var = tk.BooleanVar()
        tk.Checkbutton(root, text="Осадки", variable=self.rain_var).grid(row=3, column=0, columnspan=2)

        # Кнопка добавить
        tk.Button(root, text="Добавить запись", command=self.add_record).grid(row=4, column=0, columnspan=2, pady=10)

        # Фильтры
        tk.Label(root, text="Фильтр по дате:").grid(row=0, column=2)
        self.filter_date_var = tk.StringVar()
        tk.Entry(root, textvariable=self.filter_date_var).grid(row=0, column=3)

        tk.Label(root, text="Температура >:").grid(row=1, column=2)
        self.filter_temp_var = tk.StringVar()
        tk.Entry(root, textvariable=self.filter_temp_var).grid(row=1, column=3)

        # Кнопки фильтра
        tk.Button(root, text="Применить фильтр", command=self.apply_filter).grid(row=2, column=2, columnspan=2)
        tk.Button(root, text="Показать все", command=self.show_all).grid(row=3, column=2, columnspan=2)

        # Таблица
        columns = ('Дата', 'Температура', 'Описание', 'Осадки')
        self.tree = ttk.Treeview(root, columns=columns, show='headings')
        for col in columns:
            self.tree.heading(col, text=col)
        self.tree.grid(row=5, column=0, columnspan=4, pady=10)

        # Загружать и отображать данные
        self.load_data()
        self.show_all()

        # Сохранение при закрытии
        self.root.protocol("WM_DELETE_WINDOW", self.on_closing)

    def add_record(self):
        date_str = self.date_var.get()
        temp_str = self.temp_var.get()
        desc = self.desc_var.get()
        rain = self.rain_var.get()

        # Проверка валидности
        if not is_valid_date(date_str):
            messagebox.showerror("Ошибка", "Неправильный формат даты.")
            return
        try:
            temp = float(temp_str)
        except ValueError:
            messagebox.showerror("Ошибка", "Температура должна быть числом.")
            return
        if not desc.strip():
            messagebox.showerror("Ошибка", "Описание не должно быть пустым.")
            return

        record = {
            'date': date_str,
            'temperature': temp,
            'description': desc,
            'rain': rain
        }
        self.records.append(record)
        self.save_data()
        self.show_all()

        # Очистка полей
        self.date_var.set('')
        self.temp_var.set('')
        self.desc_var.set('')
        self.rain_var.set(False)

    def show_all(self):
        self.display_records(self.records)

    def apply_filter(self):
        filtered = self.records
        date_filter = self.filter_date_var.get()
        temp_filter = self.filter_temp_var.get()

        if date_filter:
            if is_valid_date(date_filter):
                filtered = [r for r in filtered if r['date'] == date_filter]
            else:
                messagebox.showerror("Ошибка", "Некорректный формат даты в фильтре.")
                return
        if temp_filter:
            try:
                temp_val = float(temp_filter)
                filtered = [r for r in filtered if r['temperature'] > temp_val]
            except ValueError:
                messagebox.showerror("Ошибка", "Некорректное число в фильтре по температуре.")
                return
        self.display_records(filtered)

    def display_records(self, records):
        for item in self.tree.get_children():
            self.tree.delete(item)
        for r in records:
            self.tree.insert('', tk.END, values=(
                r['date'], r['temperature'], r['description'], 'Да' if r['rain'] else 'Нет'
            ))

    def save_data(self):
        with open(DATA_FILE, 'w', encoding='utf-8') as f:
            json.dump(self.records, f, ensure_ascii=False, indent=2)

    def load_data(self):
        if os.path.exists(DATA_FILE):
            with open(DATA_FILE, 'r', encoding='utf-8') as f:
                self.records = json.load(f)

    def on_closing(self):
        self.save_data()
        self.root.destroy()

if __name__ == "__main__":
    root = tk.Tk()
    app = WeatherDiary(root)
    root.mainloop()
